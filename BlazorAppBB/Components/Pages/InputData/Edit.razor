@page "/monkeys/edit"
@using Microsoft.EntityFrameworkCore
@using BlazorAppBB.Models
@using BlazorAppBB.Data
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Input Data</h2>
<hr />
@if (IDM is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="IDM" OnValidSubmit="UpdateData" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />

                <input type="hidden" name="IDM.Id" value="@IDM.Id" />
              
                <div class="mb-3">
                    <label for="name" class="form-label">Name:</label>
                    <InputText id="name" @bind-Value="IDM.sName" class="form-control" />
                    <ValidationMessage For="() => IDM.sName" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">DateCreated:</label>
                    <InputDate id="description" @bind-Value="IDM.sMonth" class="form-control" />
                    <ValidationMessage For="() => IDM.sMonth" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">dData1:</label>
                    <InputNumber id="description" @bind-Value="IDM.dData1" class="form-control" />
                    <ValidationMessage For="() => IDM.dData1" class="text-danger" />
                </div>
               
                <div class="mb-3">
                    <label for="description" class="form-label">dData2:</label>
                    <InputNumber id="description" @bind-Value="IDM.dData2" class="form-control" />
                    <ValidationMessage For="() => IDM.dData2" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">dData3:</label>
                    <InputNumber id="description" @bind-Value="IDM.dData3" class="form-control" />
                    <ValidationMessage For="() => IDM.dData3" class="text-danger" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/monkeys">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private InputDataModel? IDM { get; set; }

    protected override async Task OnInitializedAsync()
    {
        IDM = await LoadData();

        if (IDM is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateData()
    {

        FileDataService fds = new FileDataService();
        var idms = await fds.GetDataAsync();
        var existingIdm = idms.FirstOrDefault(m => m.Id == IDM!.Id);
        if (existingIdm != null)
        {
            existingIdm.sName = IDM!.sName;
            existingIdm.sMonth = IDM.sMonth;
            existingIdm.dData1 = IDM.dData1;
            existingIdm.dData2 = IDM.dData2;
            existingIdm.dData3 = IDM.dData3;
        }
        await fds.SetDataAsync(idms);

        NavigationManager.NavigateTo("/monkeys");
    }

    private async Task<InputDataModel?> LoadData()
    {
        FileDataService fds = new FileDataService();
        var idms = await fds.GetDataAsync();
        var idm = idms.FirstOrDefault(m => m.Id == Id);

        return idm;
    }
}